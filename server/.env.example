# Copy this to .env and fill in your values

# Server
PORT=3000

# Frontend URL for CORS (your Vercel deployment URL)
CLIENT_URL=https://your-frontend.vercel.app

# MongoDB Atlas connection string (free at mongodb.com/atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatHistoryDB

# OpenAI API Key (get from platform.openai.com)
OPENAI_API_KEY=sk-proj-your_key_here

# AWS RDS PostgreSQL credentials
DB_USER=your_db_user
DB_HOST=your-rds-instance.region.rds.amazonaws.com
DB_NAME=rag
DB_PASSWORD=your_db_password
DB_PORT=5432
