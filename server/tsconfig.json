{
    "compilerOptions": {
          "target": "ES2020",
          "module": "commonjs",
          "lib": ["ES2020"],
          "outDir": "./dist",
          "rootDir": "./",
          "strict": false,
          "esModuleInterop": true,
          "allowSyntheticDefaultImports": true,
          "skipLibCheck": true,
          "resolveJsonModule": true,
          "sourceMap": true,
          "declaration": true,
          "moduleResolution": "node"
    },
    "include": [
          "**/*.ts"
    ],
    "exclude": [
          "node_modules",
          "dist"
    ]
}
